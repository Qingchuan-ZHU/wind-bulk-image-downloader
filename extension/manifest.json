{
  "manifest_version": 3,
  "name": "Wind Bulk Image Downloader",
  "short_name": "Wind Downloader",
  "version": "1.3.0",
  "description": "Local-first Chrome and Edge extension for batch downloading images from opened web pages.",
  "minimum_chrome_version": "114",
  "permissions": ["downloads", "storage", "tabs", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Wind Bulk Image Downloader",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "homepage_url": "https://github.com/Qingchuan-ZHU/wind-bulk-image-downloader"
}
